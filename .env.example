# ─────────────────────────────────────────────────────────────────────────────
# Bolted Iron Hub — local environment template
# Copy this file to `.env` (which is gitignored) and fill in the values.
# Manus uses MySQL, so local MUST be MySQL too (not PostgreSQL).
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED to boot + log in locally ───────────────────────────────────────

# Local MySQL 8.x connection string. Format:
#   mysql://<user>:<password>@<host>:<port>/<database>
# Example for the Docker command in the docs:
DATABASE_URL=mysql://root:bihpass@localhost:3306/bih

# Any random non-empty string — signs/verifies the session JWT for email login.
JWT_SECRET=change-me-to-any-long-random-string

# Must be NON-EMPTY or session verification rejects the login cookie.
# Any value is fine locally.
VITE_APP_ID=bih-local

# Dev mode (Vite middleware + readable logs)
NODE_ENV=development

# Optional — server auto-finds a free port from here if omitted (default 3000)
# PORT=3000


# ── OPTIONAL — app boots without these; only the named feature is affected ───

# Manus OAuth login button (email/password login does NOT need these locally)
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Email notifications (nodemailer / Gmail)
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=

# AI features: proposal PDF extraction + AI chat box
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
FORGE_API_KEY=

# S3 file uploads (project files / generated PDFs). Without valid AWS creds,
# uploads fail but the rest of the app runs.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# S3_BUCKET=
